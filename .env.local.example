# ── Sanity ─────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage after creating a project
# (or run `npx sanity init` — see SANITY_SETUP.md).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# API version pin (optional — defaults to 2025-01-01)
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server-side read token (only needed for private datasets / draft previews).
SANITY_API_READ_TOKEN=
# Server-side write token — used by POST /api/booking/submit (Workstream 4).
SANITY_API_WRITE_TOKEN=

# Secret shared with the Sanity webhook that pings /api/revalidate on publish.
SANITY_REVALIDATE_SECRET=

# ── Cronberry CRM (Workstream 4 — placeholders until client provides docs) ──
CRONBERRY_API_KEY=
CRONBERRY_API_URL=

# ── Fallback email (Workstream 4 — optional) ────────────────────────────────
RESEND_API_KEY=
NOTIFY_EMAIL=
